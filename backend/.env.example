# Backend Environment Variables
# Copy this to .env file in the backend directory for local development

# Ollama Configuration
OLLAMA_MODEL=mistral

# For local development (Ollama running on your machine):
OLLAMA_HOST=http://localhost:11434

# For cloud deployment (Ollama running in same container):
# OLLAMA_HOST=http://127.0.0.1:11434

# Notes Generation
NOTES_MAX_CHARS=800

# Server
PORT=8000
HOST=0.0.0.0
